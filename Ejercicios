// Función que recibe por VALOR (Copia)
SubProceso modificarPorValor ( numeroCopia Por Valor )
	numeroCopia <- numeroCopia + 50;
	Escribir "Dentro de la función (Por Valor): ", numeroCopia;
FinSubProceso

// Función que recibe por REFERENCIA (Dirección de memoria original)
SubProceso modificarPorReferencia ( numeroOriginal Por Referencia )
	numeroOriginal <- numeroOriginal + 50;
	Escribir "Dentro de la función (Por Referencia): ", numeroOriginal;
FinSubProceso

